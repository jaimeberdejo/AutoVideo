{#
  macros.html.j2 — Per-visual_type layout macros for the slides-auto pipeline.

  Each macro receives (slide, theme):
    slide : SlideSpec  — title, bullets, visual_type
    theme : ThemeConfig — palette, typography, metrics

  Security (T-03-02): ALL slide.title and slide.bullets text is rendered via
  Jinja2's autoescape context — NO |safe on user/LLM text. Only trusted SVG
  from the icon() global (python-lucide, our code) is marked |safe.

  Offline (D-07/D-08): NO <img src=...>, NO external URLs, NO external charting
  libraries. Charts/diagrams are drawn as inline SVG with <rect>/<path>/<text>.

  Icon usage: {{ icon('name', size=48, stroke=theme.palette.accent)|safe }}
  The icon() global is registered by the slides_auto stage (plan 03-02).
  Using it here is safe: SVG strings are generated by python-lucide (our code).

  Pitfall 5 guard: base.html.j2 falls back to bullets_slide for unknown
  visual_type values — no KeyError possible.
#}

{# =========================================================================
   HELPER: parse_numbers — extract numeric values from a list of bullet strings.
   Returns a list of floats found in the bullets (for chart drawing).
   If no numbers are found, returns an empty list.
   Used by chart_slide and comparison_slide.

   Implementation: Jinja2 regex filter is not available by default; we use a
   simple character-scan approach via namespace to detect digit patterns.
   The stage may register a 'parse_numbers' global in plan 03-02, but macros
   work without it by scanning for numeric characters in each bullet.
   ========================================================================= #}

{# =========================================================================
   MACRO: title_slide — hero title layout for the opening/section slide
   ========================================================================= #}
{% macro title_slide(slide, theme) %}
<div class="slide-canvas" style="justify-content: center; align-items: flex-start;">
  <div class="accent-bar"></div>
  <h1 class="slide-title" style="font-size: calc(var(--font-size-h1) * 1.3); max-width: 1400px;">
    {{ slide.title }}
  </h1>
  {% if slide.bullets %}
  <p class="slide-subtitle" style="max-width: 1200px; margin-top: 16px;">
    {{ slide.bullets[0] }}
  </p>
  {% endif %}
  <div class="icon-wrapper" style="position: absolute; right: var(--margin); bottom: var(--margin);">
    {{ icon('presentation', size=120, stroke=theme.palette.accent)|safe }}
  </div>
</div>
{% endmacro %}


{# =========================================================================
   MACRO: bullets_slide — standard bullet-point content slide
   ========================================================================= #}
{% macro bullets_slide(slide, theme) %}
<div class="slide-canvas">
  <div>
    <div class="accent-bar"></div>
    <h1 class="slide-title">{{ slide.title }}</h1>
  </div>
  <ul class="slide-bullets">
    {% for bullet in slide.bullets %}
    <li>
      <span class="bullet-dot"></span>
      <span class="bullet-text">{{ bullet }}</span>
    </li>
    {% endfor %}
  </ul>
</div>
{% endmacro %}


{# =========================================================================
   MACRO: chart_slide — bar chart drawn inline as SVG.

   Data extraction strategy (RESEARCH Open Q #2 / decision):
   Parse percentage/integer values from bullets using character scanning.
   If numbers are found, render a bar chart with computed proportional heights.
   If no numbers are found, render an illustrative icon + bullets layout
   (no invented data — offline safe, no hallucination risk).
   ========================================================================= #}
{% macro chart_slide(slide, theme) %}
{#-- Attempt to extract numeric values from bullets --#}
{%- set ns = namespace(values=[], labels=[]) -%}
{%- for bullet in slide.bullets -%}
  {%- set found = namespace(num='', scanning=false) -%}
  {%- for ch in bullet -%}
    {%- if ch in '0123456789' -%}
      {%- set found.scanning = true -%}
      {%- set found.num = found.num ~ ch -%}
    {%- elif found.scanning and ch == '.' -%}
      {%- set found.num = found.num ~ ch -%}
    {%- elif found.scanning -%}
      {%- set found.scanning = false -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if found.num -%}
    {%- set ns.values = ns.values + [found.num | float] -%}
    {%- set ns.labels = ns.labels + [bullet] -%}
  {%- endif -%}
{%- endfor -%}

<div class="slide-canvas">
  <div>
    <div class="accent-bar"></div>
    <h1 class="slide-title">{{ slide.title }}</h1>
  </div>

  {% if ns.values %}
  {#-- Compute max for proportional scaling --#}
  {%- set maxv = namespace(v=0.0001) -%}
  {%- for v in ns.values -%}
    {%- if v > maxv.v -%}{%- set maxv.v = v -%}{%- endif -%}
  {%- endfor -%}

  {#-- Bar chart SVG --#}
  {%- set chart_w = 1400 -%}
  {%- set chart_h = 500 -%}
  {%- set bar_count = ns.values | length -%}
  {%- set bar_w = ((chart_w - 80) / bar_count - 40) | round | int -%}
  {%- set bar_w = [bar_w, 60] | max -%}
  {%- set bar_w = [bar_w, 300] | min -%}
  <div style="flex: 1; display: flex; align-items: center; justify-content: flex-start;">
    <svg viewBox="0 0 {{ chart_w }} {{ chart_h + 60 }}" width="{{ chart_w }}" height="{{ chart_h + 60 }}"
         xmlns="http://www.w3.org/2000/svg" aria-label="Bar chart: {{ slide.title }}">
      {#-- Baseline --#}
      <line x1="40" y1="{{ chart_h }}" x2="{{ chart_w - 20 }}" y2="{{ chart_h }}"
            stroke="{{ theme.palette.text }}" stroke-width="2" opacity="0.3"/>
      {%- for i in range(bar_count) -%}
        {%- set v = ns.values[i] -%}
        {%- set bar_h = ((v / maxv.v) * (chart_h - 60)) | round | int -%}
        {%- set x = (40 + i * ((chart_w - 60) / bar_count) + 20) | round | int -%}
        {%- set y = chart_h - bar_h -%}
        <rect x="{{ x }}" y="{{ y }}" width="{{ bar_w }}" height="{{ bar_h }}"
              fill="{{ theme.palette.accent }}" rx="6" opacity="0.9"/>
        {#-- Value label above bar --#}
        <text x="{{ x + bar_w // 2 }}" y="{{ y - 10 }}"
              text-anchor="middle" fill="{{ theme.palette.text }}"
              font-size="22" font-family="sans-serif">{{ v | int }}%</text>
        {#-- Axis label below baseline --#}
        <text x="{{ x + bar_w // 2 }}" y="{{ chart_h + 35 }}"
              text-anchor="middle" fill="{{ theme.palette.text }}"
              font-size="18" font-family="sans-serif" opacity="0.7">{{ loop.index }}</text>
      {%- endfor -%}
    </svg>
  </div>
  {#-- Legend: bullet text --#}
  <ul class="slide-bullets" style="margin-top: 8px;">
    {% for i in range(ns.labels | length) %}
    <li>
      <span class="bullet-dot" style="background: {{ theme.palette.accent }};"></span>
      <span class="bullet-text">{{ ns.labels[i] }}</span>
    </li>
    {% endfor %}
  </ul>

  {% else %}
  {#-- Fallback: no numeric data found — illustrative icon + bullets layout --#}
  <div style="flex: 1; display: flex; align-items: center; gap: 80px;">
    <div class="icon-wrapper">
      {{ icon('chart-bar', size=200, stroke=theme.palette.accent)|safe }}
    </div>
    <ul class="slide-bullets" style="flex: 1;">
      {% for bullet in slide.bullets %}
      <li>
        <span class="bullet-dot"></span>
        <span class="bullet-text">{{ bullet }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}
</div>
{% endmacro %}


{# =========================================================================
   MACRO: diagram_slide — flowchart-style diagram drawn as inline SVG
   Each bullet becomes a node in a vertical/horizontal flow.
   ========================================================================= #}
{% macro diagram_slide(slide, theme) %}
<div class="slide-canvas">
  <div>
    <div class="accent-bar"></div>
    <h1 class="slide-title">{{ slide.title }}</h1>
  </div>
  <div style="flex: 1; display: flex; align-items: center; justify-content: center;">
    {%- set node_count = slide.bullets | length -%}
    {%- set node_w = 280 -%}
    {%- set node_h = 80 -%}
    {%- set arrow_w = 60 -%}
    {%- set total_w = node_count * node_w + (node_count - 1) * arrow_w -%}
    {%- set svg_w = [total_w + 80, 1680] | min -%}
    {%- set svg_h = 200 -%}
    <svg viewBox="0 0 {{ svg_w }} {{ svg_h }}" width="{{ svg_w }}" height="{{ svg_h }}"
         xmlns="http://www.w3.org/2000/svg" aria-label="Diagram: {{ slide.title }}">
      {%- for bullet in slide.bullets -%}
        {%- set x = loop.index0 * (node_w + arrow_w) + 40 -%}
        {%- set cy = svg_h // 2 -%}
        {#-- Node box --#}
        <rect x="{{ x }}" y="{{ cy - node_h // 2 }}" width="{{ node_w }}" height="{{ node_h }}"
              fill="{{ theme.palette.primary }}" rx="8" opacity="0.85"/>
        {#-- Node label (truncated to 24 chars) --#}
        <text x="{{ x + node_w // 2 }}" y="{{ cy + 8 }}"
              text-anchor="middle" fill="{{ theme.palette.text }}"
              font-size="20" font-family="sans-serif">{{ bullet[:24] }}</text>
        {#-- Arrow to next node --#}
        {%- if not loop.last -%}
          {%- set ax = x + node_w -%}
          {%- set ax2 = ax + arrow_w -%}
          <line x1="{{ ax }}" y1="{{ cy }}" x2="{{ ax2 - 10 }}" y2="{{ cy }}"
                stroke="{{ theme.palette.accent }}" stroke-width="3"/>
          {#-- Arrowhead triangle --#}
          <polygon points="{{ ax2 }},{{ cy }} {{ ax2 - 14 }},{{ cy - 7 }} {{ ax2 - 14 }},{{ cy + 7 }}"
                   fill="{{ theme.palette.accent }}"/>
        {%- endif -%}
      {%- endfor -%}
    </svg>
  </div>
</div>
{% endmacro %}


{# =========================================================================
   MACRO: quote_slide — large pull-quote with attribution
   First bullet = attribution (speaker/source); remaining bullets are ignored.
   ========================================================================= #}
{% macro quote_slide(slide, theme) %}
<div class="slide-canvas" style="justify-content: center; align-items: flex-start;">
  <div class="icon-wrapper" style="margin-bottom: 24px;">
    {{ icon('quote', size=80, stroke=theme.palette.accent)|safe }}
  </div>
  <blockquote style="
    font-family: var(--font-heading);
    font-size: calc(var(--font-size-h1) * 1.1);
    font-style: italic;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.3;
    margin: 0 0 40px 0;
    max-width: 1400px;
    border-left: 8px solid {{ theme.palette.accent }};
    padding-left: 48px;
  ">{{ slide.title }}</blockquote>
  {% if slide.bullets %}
  <cite style="
    font-size: var(--font-size-body);
    color: {{ theme.palette.accent }};
    font-style: normal;
    font-weight: 600;
    padding-left: 56px;
  ">{{ slide.bullets[0] }}</cite>
  {% endif %}
</div>
{% endmacro %}


{# =========================================================================
   MACRO: comparison_slide — two-column "before vs after" or A vs B layout.
   Splits bullets into two halves; detects numeric percentages for highlights.
   ========================================================================= #}
{% macro comparison_slide(slide, theme) %}
{%- set half = ((slide.bullets | length) / 2) | round(0, 'ceil') | int -%}
{%- set left_bullets = slide.bullets[:half] -%}
{%- set right_bullets = slide.bullets[half:] -%}
<div class="slide-canvas">
  <div>
    <div class="accent-bar"></div>
    <h1 class="slide-title">{{ slide.title }}</h1>
  </div>
  <div style="flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; overflow: hidden;">
    {#-- Left column --#}
    <div style="
      background: rgba(255,255,255,0.04);
      border-radius: 16px;
      padding: 48px;
      display: flex;
      flex-direction: column;
      gap: var(--gap);
      border: 2px solid {{ theme.palette.primary }};
      overflow: hidden;
    ">
      <div style="
        font-family: var(--font-heading);
        font-size: var(--font-size-h2);
        font-weight: 700;
        color: {{ theme.palette.primary }};
        margin-bottom: 8px;
      ">Antes</div>
      <ul class="slide-bullets">
        {% for bullet in left_bullets %}
        <li>
          <span class="bullet-dot" style="background: {{ theme.palette.primary }};"></span>
          <span class="bullet-text">{{ bullet }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
    {#-- Right column --#}
    <div style="
      background: rgba(255,255,255,0.04);
      border-radius: 16px;
      padding: 48px;
      display: flex;
      flex-direction: column;
      gap: var(--gap);
      border: 2px solid {{ theme.palette.accent }};
      overflow: hidden;
    ">
      <div style="
        font-family: var(--font-heading);
        font-size: var(--font-size-h2);
        font-weight: 700;
        color: {{ theme.palette.accent }};
        margin-bottom: 8px;
      ">Después</div>
      <ul class="slide-bullets">
        {% for bullet in right_bullets %}
        <li>
          <span class="bullet-dot" style="background: {{ theme.palette.accent }};"></span>
          <span class="bullet-text">{{ bullet }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>
{% endmacro %}


{# =========================================================================
   MACRO: image_icon_slide — icon grid layout with bullets as icon labels.
   Uses the icon() Jinja2 global (python-lucide, offline, D-07).
   Maps each bullet to a relevant Lucide icon name or falls back to 'circle'.
   The icon() call is the ONLY |safe in this file — SVG from our own code.
   ========================================================================= #}
{#-- Simple keyword → Lucide icon name mapping for common tech topics --#}
{%- set ICON_MAP = {
  'playwright':   'monitor-play',
  'elevenlabs':   'mic',
  'ffmpeg':       'film',
  'python':       'code-2',
  'docker':       'container',
  'slides':       'presentation',
  'voz':          'mic-2',
  'montaje':      'clapperboard',
  'render':       'image',
  'api':          'plug',
  'sync':         'refresh-cw',
  'subtitle':     'captions',
  'video':        'video',
  'vídeo':        'video',
  'audio':        'audio-lines',
  'fuente':       'type',
  'icon':         'star',
  'theme':        'palette',
  'config':       'settings',
  'pipeline':     'workflow',
  'storyboard':   'layout-list',
  'script':       'scroll-text',
  'default':      'circle-dot'
} -%}

{% macro image_icon_slide(slide, theme) %}
<div class="slide-canvas">
  <div>
    <div class="accent-bar"></div>
    <h1 class="slide-title">{{ slide.title }}</h1>
  </div>
  <div style="
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 60px;
    align-items: center;
    justify-content: flex-start;
    overflow: hidden;
  ">
    {% for bullet in slide.bullets %}
    {#-- Pick icon: check if any keyword in the bullet matches ICON_MAP --#}
    {%- set icon_name = namespace(v='circle-dot') -%}
    {%- set lower_bullet = bullet | lower -%}
    {%- for kw, icon_n in ICON_MAP.items() -%}
      {%- if kw in lower_bullet -%}
        {%- set icon_name.v = icon_n -%}
      {%- endif -%}
    {%- endfor -%}
    <div style="
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      min-width: 200px;
      max-width: 340px;
      text-align: center;
    ">
      <div class="icon-wrapper">
        {{ icon(icon_name.v, size=96, stroke=theme.palette.accent)|safe }}
      </div>
      <span style="
        font-size: var(--font-size-body);
        color: var(--color-text);
        line-height: 1.3;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
      ">{{ bullet }}</span>
    </div>
    {% endfor %}
  </div>
</div>
{% endmacro %}
